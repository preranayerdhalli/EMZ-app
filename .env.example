# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Google Calendar OAuth ────────────────────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Create one for iOS (bundle: com.emz.app) and one for Android (SHA-1 fingerprint)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com

# ─── Microsoft Outlook OAuth ─────────────────────────────────────────────────
# Azure Portal → App registrations → your-app → Application (client) ID
EXPO_PUBLIC_MICROSOFT_CLIENT_ID=your-azure-app-client-id

# ─── Edge Function Secrets (set via Supabase CLI, NOT stored in .env) ─────────
# Run: supabase secrets set GOOGLE_CLIENT_ID=... GOOGLE_CLIENT_SECRET=...
#
# GOOGLE_CLIENT_ID          (server-side, same as iOS client ID for web flow)
# GOOGLE_CLIENT_SECRET      (from Google Cloud Console)
# MICROSOFT_CLIENT_ID       (same as EXPO_PUBLIC_MICROSOFT_CLIENT_ID)
# MICROSOFT_CLIENT_SECRET   (from Azure Portal → Certificates & secrets)
