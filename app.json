{
  "expo": {
    "name": "emz",
    "slug": "emz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bee.png",
    "scheme": "emz",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#F4EFCF",
    "splash": {
      "image": "./assets/images/bee.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4EFCF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emz.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/bee.png",
        "backgroundColor": "#F4EFCF"
      },
      "package": "com.emz.app",
      "minSdkVersion": 26,
      "permissions": [
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_HEART_RATE_VARIABILITY",
        "android.permission.health.READ_RESTING_HEART_RATE",
        "android.permission.health.READ_MENSTRUATION",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_OXYGEN_SATURATION"
      ]
    },
    "plugins": [
      [
        "open-wearables",
        {
          "healthShareUsage": "EMZ reads your health data to calculate your energy levels and recovery.",
          "healthUpdateUsage": "EMZ reads your health data to calculate your energy levels and recovery."
        }
      ],
      "./plugins/withMavenLocal",
      "expo-router",
      "expo-asset",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-calendar",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.933912268834-354usg5oqgk44pt3e543hcgenr17hj02"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "41758019-aa72-463b-98f6-486fc2634967"
      }
    }
  }
}
